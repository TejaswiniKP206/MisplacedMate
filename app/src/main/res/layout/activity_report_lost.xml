<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E53935"
            android:padding="24dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEW REPORT"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Report Lost Item"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fill in the details below"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Form Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <!-- Item Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ITEM NAME"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etItemName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. Blue Water Bottle"
                    android:textColor="#000000"
                    android:textColorHint="#BDBDBD"
                    android:textCursorDrawable="@null"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Category -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CATEGORY"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp"/>

                <Spinner
                    android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Location -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LOCATION"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Where did you lose it?"
                    android:textColor="#000000"
                    android:textColorHint="#BDBDBD"
                    android:textCursorDrawable="@null"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Date -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DATE"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="DD/MM/YYYY"
                    android:textColor="#000000"
                    android:textColorHint="#BDBDBD"
                    android:textCursorDrawable="@null"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:inputType="date"
                    android:layout_marginBottom="16dp"/>

                <!-- Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESCRIPTION"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Describe the item in detail..."
                    android:textColor="#000000"
                    android:textColorHint="#BDBDBD"
                    android:textCursorDrawable="@null"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:minLines="3"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:layout_marginBottom="16dp"/>

                <!-- Contact -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTACT NUMBER"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etContact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Your phone number"
                    android:textColor="#000000"
                    android:textColorHint="#BDBDBD"
                    android:textCursorDrawable="@null"
                    android:background="#F5F5F5"
                    android:padding="12dp"
                    android:inputType="phone"
                    android:layout_marginBottom="16dp"/>

                <!-- Photo Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PHOTO"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp"/>

                <ImageView
                    android:id="@+id/imgPreview"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:background="#F5F5F5"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btnAddPhoto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Add Photo"
                        android:textColor="#E53935"
                        android:background="#FFEBEE"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btnCancelPhoto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Remove Photo"
                        android:textColor="#9E9E9E"
                        android:background="#F5F5F5"
                        android:padding="12dp"
                        android:layout_marginStart="6dp"
                        android:visibility="gone"/>

                </LinearLayout>

                <!-- Submit Button -->
                <Button
                    android:id="@+id/btnSubmitLost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Submit Report"
                    android:textColor="#FFFFFF"
                    android:background="#E53935"
                    android:padding="14dp"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>