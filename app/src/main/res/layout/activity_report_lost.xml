<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:text="Report Lost Item"
            android:textSize="24sp"
            android:layout_marginTop="30dp"
            android:textStyle="bold"
            android:textColor="#E53935"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Item Name -->
        <TextView
            android:text="Item Name"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etItemName"
            android:textColor="#000303"
            android:textCursorDrawable="@null"
            android:hint="e.g. Water Bottle, ID Card"
            android:textColorHint="#999999"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#E53935"
            android:layout_marginBottom="16dp"/>

        <!-- Category -->
        <TextView
            android:text="Category"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <Spinner
            android:id="@+id/spinnerCategory"
            android:popupBackground="#000303"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#E53935"
            android:layout_marginBottom="16dp"/>

        <!-- Location -->
        <TextView
            android:text="Last Seen Location"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etLocation"
            android:textColor="#000303"
            android:textCursorDrawable="@null"
            android:hint="e.g. Library, Canteen, Lab"
            android:textColorHint="#999999"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#E53935"
            android:layout_marginBottom="16dp"/>

        <!-- Date -->
        <TextView
            android:text="Date Lost"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etDate"
            android:textColor="#000303"
            android:textCursorDrawable="@null"
            android:hint="e.g. 28/02/2026"
            android:textColorHint="#999999"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#E53935"
            android:layout_marginBottom="16dp"/>

        <!-- Description -->
        <TextView
            android:text="Description"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etDescription"
            android:textColor="#000303"
            android:hint="Describe the item in detail"
            android:textColorHint="#999999"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="3"
            android:gravity="top"
            android:backgroundTint="#E53935"
            android:layout_marginBottom="16dp"/>

        <!-- Contact -->
        <TextView
            android:text="Your Contact Number"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etContact"
            android:textColor="#000303"
            android:textCursorDrawable="@null"
            android:hint="e.g. 9876543210"
            android:textColorHint="#999999"
            android:inputType="phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#E53935"
            android:layout_marginBottom="24dp"/>

        <!-- Image Upload -->
        <TextView
            android:text="Add Photo (Optional)"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnAddImage"
            android:text="+ Add Photo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#757575"
            android:textColor="#ffffff"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <!-- Image preview container - hidden until image selected -->
        <FrameLayout
            android:id="@+id/imageContainer"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <!-- Image preview -->
            <ImageView
                android:id="@+id/imgPreview"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:scaleType="centerCrop"
                android:background="#E0E0E0"/>

            <!-- Cancel button on top right corner of image -->
            <ImageButton
                android:id="@+id/btnCancelImage"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="top|end"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="@null"
                android:padding="0dp"/>
        </FrameLayout>

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnSubmitLost"
            android:text="Submit Report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#E53935"
            android:textColor="#ffffff"
            android:textSize="16sp"/>

    </LinearLayout>
</ScrollView>