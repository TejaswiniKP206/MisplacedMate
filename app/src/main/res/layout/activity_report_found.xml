<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:text="Report Found Item"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#43A047"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Item Name -->
        <TextView
            android:text="Item Name"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etItemName"
            android:hint="e.g. Water Bottle, ID Card"
            android:textColorHint="#999999"
            android:textColor="#000000"
            android:textCursorDrawable="@null"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#43A047"
            android:layout_marginBottom="16dp"/>

        <!-- Category -->
        <TextView
            android:text="Category"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <Spinner
            android:id="@+id/spinnerCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#43A047"
            android:layout_marginBottom="16dp"/>

        <!-- Location -->
        <TextView
            android:text="Found At Location"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etLocation"
            android:hint="e.g. Library, Canteen, Lab"
            android:textColorHint="#999999"
            android:textColor="#000000"
            android:textCursorDrawable="@null"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#43A047"
            android:layout_marginBottom="16dp"/>

        <!-- Date -->
        <TextView
            android:text="Date Found"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etDate"
            android:hint="e.g. 28/02/2026"
            android:textColorHint="#999999"
            android:textColor="#000000"
            android:textCursorDrawable="@null"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#43A047"
            android:layout_marginBottom="16dp"/>

        <!-- Description -->
        <TextView
            android:text="Description"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etDescription"
            android:hint="Describe the item in detail"
            android:textColorHint="#999999"
            android:textColor="#000000"
            android:textCursorDrawable="@null"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minLines="3"
            android:gravity="top"
            android:backgroundTint="#43A047"
            android:layout_marginBottom="16dp"/>

        <!-- Contact -->
        <TextView
            android:text="Your Contact Number"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/etContact"
            android:hint="e.g. 9876543210"
            android:textColorHint="#999999"
            android:textColor="#000000"
            android:textCursorDrawable="@null"
            android:inputType="phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#43A047"
            android:layout_marginBottom="16dp"/>

        <!-- Image Upload -->
        <TextView
            android:text="Add Photo (Optional)"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnAddImage"
            android:text="+ Add Photo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#757575"
            android:textColor="#ffffff"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

        <FrameLayout
            android:id="@+id/imageContainer"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imgPreview"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:scaleType="centerCrop"
                android:background="#E0E0E0"/>

            <ImageButton
                android:id="@+id/btnCancelImage"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="top|end"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="@null"
                android:tint="#ffffff"
                android:padding="0dp"/>

        </FrameLayout>

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnSubmitFound"
            android:text="Submit Report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#43A047"
            android:textColor="#ffffff"
            android:textSize="16sp"/>

    </LinearLayout>
</ScrollView>